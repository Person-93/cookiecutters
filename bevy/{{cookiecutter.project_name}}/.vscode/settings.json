{
  "rust-analyzer.cargo.features": ["dev"],
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.imports.preferPrelude": true,
  "rust-analyzer.imports.granularity.group": "module",
  "lldb.launch.env": {
    "LD_LIBRARY_PATH": "${workspaceFolder}/target/debug/deps;${userHome}/.rustup/toolchains/nightly-x86_64-unknown-linux-gnu/lib/rustlib/x86_64-unknown-linux-gnu/lib;${env:LD_LIBRARY_PATH}"
  },
  "files.associations": {
    "*.meta": "ron"
  },
  "maptz.regionfolder": {
    "[toml]": {
      "foldStart": "# region [NAME]",
      "foldStartRegex": "#[\\s]region[\\s]*(.*)",
      "foldEnd": "# endregion",
      "foldEndRegex": "#[\\s]*endregion"
    }
  }
}
